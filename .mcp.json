{
  "mcpServers": {
    "playwright": {
      "type": "stdio",
      "command": "npx",
      "args": [
        "@playwright/mcp@latest",
        "--browser",
        "chrome",
        "--cdp-endpoint",
        "http://localhost:9222",
        "--caps",
        "core,vision,pdf,devtools",
        "--ignore-https-errors",
        "--snapshot-mode",
        "incremental",
        "--console-level",
        "info",
        "--output-dir",
        "C:\\Users\\User\\.playwright-output-familybudget",
        "--image-responses",
        "allow"
      ],
      "env": {}
    }
  }
}